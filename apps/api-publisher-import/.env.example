# Copy to .env for local dev. Never commit a real .env — see .gitignore.

# Matches docker-compose.yml. In deployed environments, DB_AUTH_MODE=iam
# instead, and PGPASSWORD is unused — see database/database.module.ts.
DB_AUTH_MODE=password
PGHOST=localhost
PGPORT=5432
PGDATABASE=pk_literature
PGUSER=pk_literature
PGPASSWORD=pk_literature_local_dev
PGSSL=disable

PORT=3001

# Real AWS credentials/region needed to exercise the EventBridge/S3
# calls locally (staging-books.service.ts, common/eventbridge.service.ts,
# common/media-storage.service.ts) — there is no local emulation of
# these wired up (e.g. LocalStack), so local dev without valid AWS
# credentials can exercise everything except those two calls.
AWS_REGION=ap-south-1
EVENTBRIDGE_BUS_NAME=pk-literature-dev
MEDIA_BUCKET_NAME=pk-literature-dev-media
