{
  "name": "api-publisher-import",
  "version": "0.0.0",
  "private": true,
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/main.ts\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "package:lambda": "bash scripts/package-lambda.sh"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.687.0",
    "@aws-sdk/client-s3": "^3.687.0",
    "@aws-sdk/rds-signer": "^3.687.0",
    "@codegenie/serverless-express": "^4.16.0",
    "@nestjs/common": "^10.4.6",
    "@nestjs/core": "^10.4.6",
    "@nestjs/platform-express": "^10.4.6",
    "@pk-literature/adapter-sdk": "workspace:*",
    "@pk-literature/contracts": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "kysely": "^0.27.4",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@pk-literature/eslint-config": "workspace:*",
    "@pk-literature/tsconfig": "workspace:*",
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
