# Copy to .env for local dev. Never commit a real .env — see .gitignore.

# Matches docker-compose.yml. In deployed environments, DB_AUTH_MODE=iam
# instead, and PGPASSWORD is unused — see database/database.module.ts.
DB_AUTH_MODE=password
PGHOST=localhost
PGPORT=5432
PGDATABASE=pk_literature
PGUSER=pk_literature
PGPASSWORD=pk_literature_local_dev
PGSSL=disable

PORT=3005

AWS_REGION=ap-south-1
EVENTBRIDGE_BUS_NAME=pk-literature-dev

# JWT signing secret — auth/jwt.service.ts. Deployed environments
# resolve JWT_SIGNING_SECRET_ARN via Secrets Manager instead (see
# common/resolve-secret-env-vars.ts); set this plain value for local
# dev only.
JWT_SIGNING_SECRET=local-dev-only-not-a-real-secret

# auth/auth.controller.ts — scopes auth cookies to every subdomain of
# the deployed domain (apps/web and this API are siblings, e.g.
# www.pk-literature.example / api.pk-literature.example) so apps/web's
# server-side fetches actually receive them back. Leave unset for local
# dev/test — there's no shared parent domain against localhost, and an
# unset value falls back to normal host-only cookie scoping.
# COOKIE_DOMAIN=.pk-literature.example
