# Copy to .env.local for local dev. Never commit a real .env* file —
# see .gitignore. All of these are build-time/runtime env vars the
# server reads directly (App Router Server Components run server-side,
# so these never need the NEXT_PUBLIC_ prefix except where a Client
# Component also reads them directly, noted below).

# API Gateway base URL — every service's routes share one HTTP API
# (terraform/modules/api-gateway). Local dev points at nothing real by
# default; run the API Lambdas locally (each app's own `pnpm start:dev`)
# or point this at a deployed dev environment. Two variables, not one:
# src/lib/api/server-fetch.ts (Server Components, Node's fetch) reads
# the plain one; src/lib/api/client-fetch.ts (Client Components,
# browser fetch) needs the NEXT_PUBLIC_ copy to be inlined into the
# browser bundle at build time. Keep them equal in every environment —
# see apps/web/README.md for why there are two at all.
API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Read by next.config.ts at build time (next/image remotePatterns) AND
# by Client Components rendering <img> fallbacks directly — needs the
# NEXT_PUBLIC_ prefix to be available in the browser bundle.
NEXT_PUBLIC_CDN_HOST=cdn.dev.pk-literature.example

# Razorpay Checkout.js widget (apps/web/src/components/checkout-form.tsx)
# needs the publishable key ID client-side to open the payment sheet —
# never the key secret, which never leaves apps/api-commerce. Left
# blank; no real Razorpay credentials exist in this environment (same
# disclosure as apps/api-commerce/src/payments/razorpay.client.ts).
NEXT_PUBLIC_RAZORPAY_KEY_ID=
