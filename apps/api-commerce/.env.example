# Copy to .env for local dev. Never commit a real .env — see .gitignore.

# Matches docker-compose.yml. In deployed environments, DB_AUTH_MODE=iam
# instead, and PGPASSWORD is unused — see database/database.module.ts.
DB_AUTH_MODE=password
PGHOST=localhost
PGPORT=5432
PGDATABASE=pk_literature
PGUSER=pk_literature
PGPASSWORD=pk_literature_local_dev
PGSSL=disable

PORT=3004

# Matches the cdn.<domain> alias the cloudfront Terraform module
# creates. Only used to build public media URLs — see common/media-url.ts.
CDN_BASE_URL=http://localhost:9000

AWS_REGION=ap-south-1
EVENTBRIDGE_BUS_NAME=pk-literature-dev

# Razorpay — no real sandbox credentials available in this environment;
# see payments/razorpay.client.ts's own disclosure. Leave unset locally
# unless you have real Razorpay test-mode keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
