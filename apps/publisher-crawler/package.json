{
  "name": "publisher-crawler",
  "version": "0.0.0",
  "private": true,
  "description": "Adapter runner — discover/fetch/normalize (SPEC-04 §6), invoked by a GitHub Actions workflow, not deployed to AWS (ADR-009). Not a Lambda: no scripts/package-lambda.sh, no dist-lambda.zip.",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/credential-provider-node": "^3.687.0",
    "@pk-literature/adapter-sdk": "workspace:*",
    "@smithy/protocol-http": "^4.1.4",
    "@smithy/signature-v4": "^4.2.0"
  },
  "devDependencies": {
    "@pk-literature/eslint-config": "workspace:*",
    "@pk-literature/tsconfig": "workspace:*",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
