# Copy to .env for local dev. Never commit a real .env — see .gitignore.
# In deployed environments these come from Secrets Manager via ECS
# task-definition `secrets` (terraform/environments/<env>/medusa.tf),
# not a committed .env file.

# medusa-config.ts assembles DATABASE_URL from these at boot — see its
# own comment for why (matches ECS `secrets`, which can only inject one
# plain value per env var, not a pre-assembled connection string).
# DATABASE_SCHEMA defaults to "medusa" in medusa-config.ts already.
PGHOST=localhost
PGPORT=5432
PGUSER=medusa_app
PGPASSWORD=medusa_local_dev
PGDATABASE=pk_literature

STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000
JWT_SECRET=local-dev-only-not-a-real-secret
COOKIE_SECRET=local-dev-only-not-a-real-secret

AWS_REGION=ap-south-1
EVENTBRIDGE_BUS_NAME=pk-literature-dev
